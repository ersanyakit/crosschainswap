VITE_EXCHANGE_API_URL="/api"
VITE_EXCHANGE_WS_URL=""
VITE_EXCHANGE_USER_ID="demo-user"
VITE_EXCHANGE_PROXY_TARGET="http://127.0.0.1:8080"

# Local OIDC callback should use the backend endpoint registered in the OIDC client.
# The backend redirects back to the frontend after writing the HTTP-only session cookie.
# OIDC_REDIRECT_URI="http://localhost:8080/auth/oidc/callback"
#
# Keep OIDC_CLIENT_SECRET only in the backend .env file, never in VITE_* env.
#
# Backend OIDC redirect allow-list should include the frontend origin in production:
# OIDC_ALLOWED_REDIRECT_ORIGINS="https://your-frontend.example"
# OIDC_POST_LOGIN_REDIRECT_URL="https://your-frontend.example/"
